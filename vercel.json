{
  "redirects": [
    {
      "source": "/sitemap_index.xml",
      "destination": "/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "broadpost.vercel.app"
        }
      ],
      "destination": "https://thebroadpost.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.thebroadpost.com"
        }
      ],
      "destination": "https://thebroadpost.com/:path*",
      "permanent": true
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon-32x32.png"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
